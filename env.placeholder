# API and data — copy this file to ".env" in the project root, then fill in real values.
#   cp env.placeholder .env
# The real ".env" is gitignored. This "env.placeholder" file is the committed template only.

# Run the app from the repository root so .env and APPLYPILOT_DIR resolve.

# ---------------------------------------------------------------------------
# Data directory
# ---------------------------------------------------------------------------
# Bundled fake profile for tests (safe to commit in demo/user-data):
APPLYPILOT_DIR=demo/user-data

# ---------------------------------------------------------------------------
# LLM — at least one is required for scoring / tailoring (set a real key in .env)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-key-here
# LLM_URL=http://127.0.0.1:8080/v1
# LLM_MODEL=

# ---------------------------------------------------------------------------
# Auto-apply (optional)
# ---------------------------------------------------------------------------
# CAPSOLVER_API_KEY=your-capsolver-key-here

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# CHROME_PATH=/path/to/chrome
# PROXY=host:port:user:pass
